# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL
POSTGRES_DB=smartlife
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# JWT (longue chaîne aléatoire, ex: openssl rand -hex 64)
JWT_SECRET=your_jwt_secret_here

# Internal service secret (backend → ai-service)
AI_INTERNAL_SECRET=your_internal_secret_here

# Email (pour 2FA OTP - laisser vide pour désactiver)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
OTP_ENABLED=false
