<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme (used after splash) -->
    <style name="Theme.SmartLife" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">#0D1117</item>
        <item name="android:navigationBarColor">#0D1117</item>
        <item name="android:windowBackground">#0D1117</item>
    </style>

    <!-- Splash screen theme — extends SplashScreen compat -->
    <style name="Theme.SmartLife.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D1117</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">#161B22</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartLife</item>
    </style>

</resources>
